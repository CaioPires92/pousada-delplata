generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RoomType {
  id                            String                         @id @default(uuid())
  name                          String
  description                   String
  capacity                      Int
  maxGuests                     Int                            @default(3)
  inventoryFor4Guests           Int                            @default(0)
  includedAdults                Int                            @default(2)
  totalUnits                    Int                            @default(1)
  basePrice                     Decimal
  extraAdultFee                 Decimal                        @default(0)
  child6To11Fee                 Decimal                        @default(0)
  amenities                     String
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  externalId                    String?
  bookings                      Booking[]
  fourGuestInventoryAdjustments FourGuestInventoryAdjustment[]
  inventory                     InventoryAdjustment[]
  photos                        Photo[]
  rates                         Rate[]
}

model Photo {
  id         String   @id @default(uuid())
  url        String
  position   Int      @default(0)
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

model Rate {
  id         String   @id @default(uuid())
  roomTypeId String
  startDate  DateTime
  endDate    DateTime
  price      Decimal
  cta        Boolean  @default(false)
  ctd        Boolean  @default(false)
  stopSell   Boolean  @default(false)
  minLos     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, startDate, endDate])
}

model InventoryAdjustment {
  id         String   @id @default(uuid())
  roomTypeId String
  date       DateTime
  dateKey    String
  totalUnits Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, dateKey])
  @@index([dateKey])
}

model FourGuestInventoryAdjustment {
  id         String   @id @default(uuid())
  roomTypeId String
  date       DateTime
  dateKey    String
  totalUnits Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, dateKey])
  @@index([dateKey])
}

model Guest {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id                 String            @id @default(uuid())
  guestId            String
  roomTypeId         String
  adults             Int               @default(1)
  children           Int               @default(0)
  childrenAges       String?
  checkIn            DateTime
  checkOut           DateTime
  totalPrice         Decimal
  subtotalPrice      Decimal?
  discountAmount     Decimal?
  appliedCouponCode  String?
  status             String
  pendingEmailSentAt DateTime?
  expiredEmailSentAt DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  roomType           RoomType          @relation(fields: [roomTypeId], references: [id])
  guest              Guest             @relation(fields: [guestId], references: [id])
  couponRedemption   CouponRedemption?
  payment            Payment?
}

model Payment {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  amount       Decimal
  provider     String
  providerId   String?
  method       String?
  cardBrand    String?
  installments Int?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id])
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  id                 String             @id @default(uuid())
  name               String
  codeHash           String             @unique
  codePrefix         String
  type               String
  value              Decimal
  maxDiscountAmount  Decimal?
  minBookingValue    Decimal?
  active             Boolean            @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  maxGlobalUses      Int?
  maxUsesPerGuest    Int?
  bindEmail          String?
  bindPhone          String?
  allowedRoomTypeIds String?
  allowedSources     String?
  singleUse          Boolean            @default(true)
  stackable          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  attemptLogs        CouponAttemptLog[]
  redemptions        CouponRedemption[]

  @@index([codePrefix])
  @@index([active])
  @@index([startsAt, endsAt])
}

model CouponRedemption {
  id             String    @id @default(uuid())
  couponId       String
  status         String    @default("RESERVED")
  bookingId      String?   @unique
  guestEmail     String?
  guestPhone     String?
  discountAmount Decimal   @default(0)
  reservedAt     DateTime  @default(now())
  expiresAt      DateTime?
  confirmedAt    DateTime?
  releasedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  booking        Booking?  @relation(fields: [bookingId], references: [id])
  coupon         Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId, status])
  @@index([guestEmail, couponId])
}

model CouponAttemptLog {
  id            String   @id @default(uuid())
  couponId      String?
  codePrefix    String?
  guestEmail    String?
  ipHash        String?
  userAgentHash String?
  result        String
  reason        String?
  createdAt     DateTime @default(now())
  coupon        Coupon?  @relation(fields: [couponId], references: [id])

  @@index([createdAt])
  @@index([codePrefix])
}

model Contact {
  id              String              @id @default(uuid())
  name            String?
  phoneRaw        String?
  phoneNormalized String?             @unique
  whatsappLid     String?             @unique
  whatsappJid     String?             @unique
  email           String?
  source          String              @default("manual")
  status          String              @default("lead")
  optInWhatsapp   Boolean             @default(false)
  optOutAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  conversations   Conversation[]
  pipelineCards   PipelineCard[]
  actionLogs      InternalActionLog[]

  @@index([email])
  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id                    String              @id @default(uuid())
  contactId             String
  channel               String
  status                String              @default("open")
  chatbotEnabled        Boolean             @default(false)
  automationPausedUntil DateTime?
  assignedUserId        String?
  lastMessageAt         DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  contact               Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages              Message[]
  pipelineCards         PipelineCard[]
  internalNotes         InternalNote[]
  actionLogs            InternalActionLog[]

  @@index([contactId])
  @@index([channel, status])
  @@index([assignedUserId])
  @@index([lastMessageAt])
}

model Message {
  id                String       @id @default(uuid())
  conversationId    String
  externalMessageId String?
  senderType        String
  content           String?
  messageType       String       @default("text")
  mediaUrl          String?
  metadataJson      String?
  sentAt            DateTime
  createdAt         DateTime     @default(now())
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, externalMessageId])
  @@index([conversationId, sentAt])
  @@index([senderType])
  @@index([messageType])
}

model PipelineCard {
  id             String        @id @default(uuid())
  contactId      String
  conversationId String?
  stage          String        @default("novo")
  priority       String        @default("media")
  assignedUserId String?
  source         String        @default("manual")
  lastActivityAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  estimatedValue Float?
  intendedArrival DateTime?
  lossReason     String?
  bookingId      String?
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([conversationId])
  @@index([stage, priority])
  @@index([assignedUserId])
  @@index([lastActivityAt])
}

model ChatbotSettings {
  id                            String   @id @default(uuid())
  enabledGlobal                 Boolean  @default(false)
  enabledWhatsapp               Boolean  @default(false)
  enabledSite                   Boolean  @default(false)
  defaultHandoffMessage         String?
  maxAutoReplyDelaySeconds      Int      @default(30)
  staleAvailabilityLimitMinutes Int      @default(60)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model ChatbotRule {
  id        String   @id @default(uuid())
  trigger   String   @unique
  response  String
  category  String   @default("faq")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternalActionLog {
  id             String        @id @default(uuid())
  userId         String?
  contactId      String?
  conversationId String?
  bookingId      String?
  action         String
  metadataJson   String?
  createdAt      DateTime      @default(now())
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactId])
  @@index([conversationId])
  @@index([bookingId])
  @@index([action])
  @@index([createdAt])
}

model InternalNote {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String?
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([createdAt])
}
